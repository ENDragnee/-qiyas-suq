# Backend environment template.
#
# IMPORTANT — where this file must live:
#   Two mechanisms load these vars:
#   1. dotenv: src/index.ts calls `dotenv.config({ path: "../.env" })`, which
#      dotenv resolves RELATIVE TO THE PROCESS CWD (not the file). Started from
#      backend/, "../.env" points at the repo root (-qiyas-suq/.env).
#   2. Bun: when run with `bun`, Bun ALSO auto-loads a `.env` from its cwd
#      (backend/.env). So in practice the simplest setup is to copy this file
#      to `backend/.env` — Bun reads it automatically.
#   Either copy this to backend/.env (recommended) or to <repo-root>/.env, or
#   pass the values inline on the `bun` command (what the seed script does).

# HTTP/GraphQL listen port
PORT=3000

# MongoDB connection string. The dockerized Mongo creates its root user in the
# "admin" database, so authSource MUST be admin (not the default "suq") or
# authentication fails.
DATABASE_URL=mongodb://suq:qazwsxedc@localhost:27017/suq?authSource=admin

# Session cookie signing secret — use a strong random value in production.
SESSION_SECRET=dev-secret-change-me

# bcrypt salt rounds (required; the app throws if missing/NaN).
ROUND_SALT=10

# Set to "production" to hide raw error details from API responses.
ENVIRONMENT=development
